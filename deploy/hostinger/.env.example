# Unique on this VPS (avoids Traefik/router name clashes).
COMPOSE_PROJECT_NAME=hsonboard01

# DNS A/AAAA → VPS; same hostname Traefik routes.
WEB_FQDN=onboard.yourdomain.com

TRAEFIK_CERT_RESOLVER=letsencrypt

# If Traefik shows 502, set its Docker network name and use both compose files:
# TRAEFIK_DOCKER_NETWORK=web
# docker compose -f docker-compose.yml -f docker-compose.traefik-network.yml --env-file .env up -d --build

# Baked into the SPA at build time (Kong / project URL).
VITE_SUPABASE_URL=https://your-supabase-kong.example.com
VITE_SUPABASE_ANON_KEY=eyJ...

# Edge Functions: PUBLIC_APP_VERIFY_URL=https://onboard.yourdomain.com (no trailing slash)
