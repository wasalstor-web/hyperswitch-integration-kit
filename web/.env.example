# انسخ إلى .env.local ثم: npm run dev
# Copy to .env.local then: npm run dev

# Supabase project URL (Dashboard → Settings → API)
# مثال لوحة المشروع: https://supabase.com/dashboard/project/YOUR_REF/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon (public) key — never commit .env.local or use service_role in the browser
VITE_SUPABASE_ANON_KEY=eyJ...

# Edge Functions: set secret PUBLIC_APP_VERIFY_URL to the same origin users open in the browser
# (e.g. http://localhost:5173 for dev, https://onboard.example.com for production, no trailing slash)
