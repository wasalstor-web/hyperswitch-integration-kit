# انسخ إلى .env.local ثم: npm run dev
# Copy to .env.local then: npm run dev

# ─── وضع أ: خادم محلي + Prisma (npm run server:dev من جذر المشروع + DATABASE_URL في .env) ───
# VITE_API_BASE_URL=http://localhost:8788
# إن ضبطت INTERNAL_API_KEY في .env الجذر ضع نفس القيمة هنا:
# VITE_INTERNAL_API_KEY=

# ─── وضع ب: Supabase (Edge Functions) ───
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# يجب تعريف إما VITE_API_BASE_URL أو (VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY)

# PUBLIC_APP_VERIFY_URL على الخادم (أسرار Edge أو .env الجذر) يجب أن يطابق أصل الواجهة، مثلاً:
# http://localhost:5173
