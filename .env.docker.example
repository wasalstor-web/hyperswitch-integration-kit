# نسخ إلى .env.docker لـ docker compose --env-file .env.docker
# المتغيرات أدناه تُكمِل/تستبدل قيم docker-compose.yml للخدمة api

PUBLIC_APP_VERIFY_URL=http://localhost:5173
API_PUBLISH_PORT=8788

# اختياري للإنتاج:
# CORS_ORIGIN=https://onboarding.example.com
# INTERNAL_API_KEY=
# HYPERSWITCH_BASE_URL=
# HYPERSWITCH_ADMIN_API_KEY=
# MESSAGE_GATEWAY_URL=https://your-real-gateway/send
# (إذا غيّرت الرسائل إلى بوابة حقيقية، يمكنك إزالة خدمة mock-gateway من compose محلياً)

# بوابة دفع OAuth2 (اختياري — انظر docs/PAYMENT_GATEWAY_TRIAL_AR.md)
# PAYMENT_GATEWAY_TOKEN_URL=
# PAYMENT_GATEWAY_CLIENT_ID=
# PAYMENT_GATEWAY_CLIENT_SECRET=
# PAYMENT_GATEWAY_MERCHANT_PROFILE=
# PAYMENT_GATEWAY_PROBE_ENABLED=true
# EdfaPay (اختياري): انظر docs/EDFAPAY_MUBASAT_AR.md
# EDFAPAY_CLIENT_KEY=
# EDFAPAY_HASH_PASSWORD=
# EDFAPAY_MERCHANT_PROFILE=
# EDFAPAY_MERCHANT_CODE=
# EDFAPAY_PROBE_ENABLED=true
