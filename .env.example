# نسخ إلى .env وعدّل القيم — الملف .env لا يُرفع إلى git

# ─── Postgres مباشر (Prisma) ─────────────────────────────────
# مثال مع docker-compose.dev.yml: postgresql://app:app@127.0.0.1:5433/onboarding
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# تشغيل بدون Docker: Postgres مضمّن (PGlite) — يتجاهل الاتصال بـ DATABASE_URL للاستعلام عبر Prisma adapter
# USE_PGLITE=true
# PGLITE_DATA_DIR=.data/pglite

# ─── خادم API المحلي (server) ───────────────────────────────
PORT=8788
PUBLIC_APP_VERIFY_URL=http://localhost:5173
# إنتاج: أصول مسموحة مفصولة بفواصل (CORS). بدونها يُستخدم * في التطوير.
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
# اختياري: حماية الـ API — يجب أن يطابق VITE_INTERNAL_API_KEY في web/.env.local
# INTERNAL_API_KEY=

# تطوير فقط
DANGEROUS_RETURN_TOKEN=true
DANGEROUS_RETURN_OTP=true
# DANGEROUS_RETURN_HS_JWT=true

# بوابة رسائل (اختياري)
# MESSAGE_GATEWAY_URL=
# MESSAGE_GATEWAY_KEY=

# Hyperswitch (خطوة 5 — اختياري للتجربة بدون بلوحة)
# HYPERSWITCH_BASE_URL=
# HYPERSWITCH_ADMIN_API_KEY=
# HYPERSWITCH_REGISTRATION_MODE=public_signup

# ─── واجهة الويب (web/.env.local منفصل) ─────────────────────
# VITE_API_BASE_URL=http://localhost:8788
# VITE_INTERNAL_API_KEY=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
